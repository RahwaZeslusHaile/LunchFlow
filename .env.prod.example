# ============================================================
# LunchFlow Production Environment Variables
# Copy this file, fill in the values, and set them in Coolify
# ============================================================

# --- Database ---
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DB_NAME=launch
DB_PORT=5432
DB_SSL=false

# --- Backend ---
JWT_SECRET=change-me-strong-jwt-secret-at-least-32-chars

# --- Frontend URL (for CORS / email links) ---
FRONTEND_URL=https://lunch_flow_frontend.hosting.codeyourfuture.io

# --- Email (Nodemailer / Gmail) ---
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password


